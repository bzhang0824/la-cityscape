# Supabase PostgreSQL connection string
# Found in: Supabase Dashboard > Project Settings > Database > Connection string > URI
# Use the "Transaction" pooler (port 6543) for pipelines, or "Session" pooler for long-lived connections
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-west-1.pooler.supabase.com:6543/postgres

# Supabase API (for frontend direct access + auth)
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key...

# Optional — increases Socrata API rate limit from 1000/hr to 40000/hr
SOCRATA_APP_TOKEN=

# Optional — for geocoding (Nominatim is free, no key needed)
# GEOCODE_API_KEY=
